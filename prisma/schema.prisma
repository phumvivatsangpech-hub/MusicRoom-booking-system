generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  CONFIRMED
  IN_USE
  COMPLETED
  CANCELLED
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  studentId     String?
  faculty       String?
  role          Role      @default(USER)
  banUntil      DateTime?
  banReason     String?
  instruments   String[]  @default([])
  createdAt     DateTime  @default(now())

  accounts   Account[]
  sessions   Session[]
  bookings   Booking[]
  complaints Complaint[]
  posts      Post[]
  comments   Comment[]
  reports    Report[]
  pollVotes  PollVote[]
  postLikes  PostLike[]
}

model Booking {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  date           DateTime
  startTime      String
  endTime        String
  status         BookingStatus @default(CONFIRMED)
  photoBeforeUrl String?
  photoAfterUrl  String?
  createdAt      DateTime      @default(now())
}

model Complaint {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  title     String
  content   String
  photoUrl  String?
  status    ComplaintStatus @default(PENDING)
  adminNote String?
  createdAt DateTime        @default(now())
}

model Post {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  content    String
  mediaUrl   String?
  mediaType  MediaType?
  isDeleted  Boolean    @default(false)
  isPinned   Boolean    @default(false)
  isPoll     Boolean    @default(false)
  isApproved Boolean    @default(true)
  createdAt  DateTime   @default(now())

  comments    Comment[]
  reports     Report[]
  pollOptions PollOption[]
  pollVotes   PollVote[]
  likes       PostLike[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  mediaUrl  String?
  mediaType MediaType?
  parentId  String?
  parent    Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentToComment")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Report {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  createdAt DateTime @default(now())
}

model PollOption {
  id        String     @id @default(cuid())
  postId    String
  post      Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  text      String
  votes     PollVote[]
}

model PollVote {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pollOptionId String
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  postId       String
  post         Post       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

enum EventType {
  CLOSURE
  ANNOUNCEMENT
}

model CalendarEvent {
  id        String    @id @default(cuid())
  title     String
  type      EventType
  date      DateTime
  startTime String?
  endTime   String?
  createdAt DateTime  @default(now())
}